{%- comment -%}
  Cart Progress Bar for Shopify
  Shows customers how close they are to getting:
    1. Free shipping (at €39.99)
    2. A free gift product (at €99.99)
  Settings can be changed in the Theme Editor — no code needed
{%- endcomment -%}

{%- liquid

  # Shopify stores all prices in cents, so we convert euros to cents
  # Example: 39.99 euros becomes 3999 cents
  assign shipping_limit = section.settings.free_shipping_threshold | times: 100
  assign gift_limit = section.settings.free_gift_threshold | times: 100
  assign gift_variant_id = section.settings.free_gift_variant_id

  # Get the total price of all products in the cart (in cents)
  assign cart_total = cart.items_subtotal_price

  # Figure out how full the bar should be
  # We split the bar in half: left half = shipping goal, right half = gift goal
  # This way the bar always grows and never goes backwards
  if cart_total >= gift_limit
    # Customer got both rewards
    assign progress = 100
    assign status_text = 'Sie erhalten ein Geschenk & Versand kostenlos!'
    assign helper_text = ''
    assign bar_state = 'complete'
  elsif cart_total >= shipping_limit
    # Free shipping unlocked, now working toward the free gift
    assign gift_range = gift_limit | minus: shipping_limit
    assign gift_progress = cart_total | minus: shipping_limit | times: 50 | divided_by: gift_range
    assign progress = 50 | plus: gift_progress
    assign remaining_cents = gift_limit | minus: cart_total
    assign remaining = remaining_cents | money_without_trailing_zeros
    assign status_text = 'Kostenloses Geschenk ab ' | append: gift_limit | divided_by: 100.0 | money
    assign helper_text = 'Noch ' | append: remaining | append: ' bis zum kostenlosen Geschenk'
    assign bar_state = 'active'
  else
    # Still working toward free shipping
    assign progress = cart_total | times: 50 | divided_by: shipping_limit
    assign remaining_cents = shipping_limit | minus: cart_total
    assign remaining = remaining_cents | money_without_trailing_zeros
    assign status_text = 'Kostenloser Versand ab ' | append: shipping_limit | divided_by: 100.0 | money
    assign helper_text = 'Noch ' | append: remaining | append: ' bis zum kostenlosen Versand'
    assign bar_state = 'active'
  endif
-%}

<!-- The main wrapper -->
<!-- data-* attributes let JavaScript read the settings later -->
<!-- role="progressbar" + aria-* make it work with screen readers -->
<div class="cart-progress"
     data-section-id="{{ section.id }}"
     data-shipping-threshold="{{ shipping_limit }}"
     data-gift-threshold="{{ gift_limit }}"
     data-gift-variant-id="{{ gift_variant_id }}"
     role="progressbar"
     aria-valuenow="{{ progress }}"
     aria-valuemin="0"
     aria-valuemax="100"
     aria-label="{{ status_text }}">

  <!-- Text above the bar: tells the customer their current goal -->
  <p class="cart-progress__status{% if bar_state == 'complete' %} cart-progress__status--success{% endif %}">
    {{ status_text }}
  </p>

  <!-- The bar itself: gray track with a colored fill -->
  <div class="cart-progress__track">
    <div class="cart-progress__fill{% if bar_state == 'complete' %} cart-progress__fill--complete{% endif %}"
         style="width: {{ progress | at_most: 100 }}%">
    </div>
  </div>

  <!-- Text below the bar: shows how much more to spend (hidden when done) -->
  {%- if helper_text != blank -%}
    <p class="cart-progress__helper">{{ helper_text }}</p>
  {%- endif -%}
</div>

<style>
  /* The rounded card that wraps everything */
  .cart-progress {
    background: #F0F4F6;
    border-radius: 10px;
    padding: 14px 16px;
    margin: 16px 0;
    transition: background 0.4s ease;
  }
  /* Turns green when both rewards are unlocked */
  .cart-progress.is-complete { background: #e8f5e0; }

  /* Text above the bar */
  .cart-progress__status {
    font-size: 13px;
    font-weight: 500;
    color: #002F6C;
    margin: 0 0 10px;
    transition: color 0.4s ease;
  }
  /* Green text when done */
  .cart-progress__status--success { color: #4A9500; }

  /* The gray background of the bar */
  .cart-progress__track {
    height: 7px;
    background: #d0d8de;
    border-radius: 4px;
    overflow: hidden;
  }

  /* The blue fill that grows as you add items */
  .cart-progress__fill {
    height: 100%;
    background: #002F6C;
    border-radius: 4px;
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  /* Green fill when done */
  .cart-progress__fill--complete { background: #4A9500; }

  /* Small text below the bar */
  .cart-progress__helper {
    font-size: 12px;
    color: #6b6d70;
    margin: 8px 0 0;
  }
</style>

<!-- JavaScript: updates the bar in real-time when items are added/removed -->
<script>
  (function() {
    var el = document.querySelector('.cart-progress');
    if (!el) return;

    // Read the settings from the HTML
    var SHIPPING = parseInt(el.dataset.shippingThreshold, 10);
    var GIFT = parseInt(el.dataset.giftThreshold, 10);
    var GIFT_VARIANT = el.dataset.giftVariantId;
    var debounceTimer;

    // Turn cents into a nice euro string: 3999 → "39,99€"
    function formatMoney(cents) {
      return (cents / 100).toLocaleString('de-DE', {
        minimumFractionDigits: 2, maximumFractionDigits: 2
      }) + '\u20AC';
    }

    // Get the current cart from Shopify
    async function getCart() {
      return (await fetch('/cart.json')).json();
    }

    // Add the free gift product to the cart
    async function addGift() {
      await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [{ id: GIFT_VARIANT, quantity: 1 }] })
      });
    }

    // Remove the free gift from the cart
    async function removeGift(lineIndex) {
      await fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: lineIndex, quantity: 0 })
      });
    }

    // This runs every time the cart changes
    async function update() {
      var cart = await getCart();
      var total = cart.items_subtotal_price;
      var hasGift = cart.items.some(function(i) { return String(i.variant_id) === GIFT_VARIANT; });

      // If cart is above the gift limit, add the gift automatically
      // If cart drops below the gift limit, remove it
      if (total >= GIFT && !hasGift) { await addGift(); return update(); }
      if (total < GIFT && hasGift) {
        var idx = cart.items.findIndex(function(i) { return String(i.variant_id) === GIFT_VARIANT; });
        if (idx !== -1) { await removeGift(idx + 1); return update(); }
      }

      // Calculate how full the bar should be
      var progress, statusText, helperText, isComplete;
      if (total >= GIFT) {
        progress = 100;
        statusText = 'Sie erhalten ein Geschenk & Versand kostenlos!';
        helperText = ''; isComplete = true;
      } else if (total >= SHIPPING) {
        progress = 50 + ((total - SHIPPING) / (GIFT - SHIPPING)) * 50;
        statusText = 'Kostenloses Geschenk ab ' + formatMoney(GIFT);
        helperText = 'Noch ' + formatMoney(GIFT - total) + ' bis zum kostenlosen Geschenk';
        isComplete = false;
      } else {
        progress = (total / SHIPPING) * 50;
        statusText = 'Kostenloser Versand ab ' + formatMoney(SHIPPING);
        helperText = 'Noch ' + formatMoney(SHIPPING - total) + ' bis zum kostenlosen Versand';
        isComplete = false;
      }

      // Put the new values on the page
      var fill = el.querySelector('.cart-progress__fill');
      var status = el.querySelector('.cart-progress__status');
      var helper = el.querySelector('.cart-progress__helper');
      fill.style.width = progress + '%';
      fill.classList.toggle('cart-progress__fill--complete', isComplete);
      status.textContent = statusText;
      status.classList.toggle('cart-progress__status--success', isComplete);
      el.classList.toggle('is-complete', isComplete);
      el.setAttribute('aria-valuenow', Math.round(progress));
      if (helper) { helper.textContent = helperText; helper.style.display = helperText ? '' : 'none'; }
    }

    // Wait a tiny bit before updating (stops it from running too many times if someone clicks fast)
    document.addEventListener('cart:change', function() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(update, 150);
    });
  })();
</script>

<!-- These settings show up in the Shopify Theme Editor -->
<!-- Store managers can change the values without touching code -->
{% schema %}
{
  "name": "Cart Progress Bar",
  "settings": [
    {
      "type": "number",
      "id": "free_shipping_threshold",
      "label": "Free Shipping Limit (€)",
      "default": 39.99,
      "info": "How much the customer needs to spend for free shipping"
    },
    {
      "type": "number",
      "id": "free_gift_threshold",
      "label": "Free Gift Limit (€)",
      "default": 99.99,
      "info": "How much the customer needs to spend to get a free gift"
    },
    {
      "type": "text",
      "id": "free_gift_variant_id",
      "label": "Gift Product Variant ID",
      "info": "The ID of the free gift product (find it in Shopify Admin > Products)"
    }
  ]
}
{% endschema %}
